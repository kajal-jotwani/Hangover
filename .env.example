# ---- CodeMind environment ----
# Copy to .env and fill in. Never commit .env.

# ===== Cognee Cloud =====
# API Base URL for your tenant (the serve() service URL).
COGNEE_URL=https://your-tenant.cognee.ai
# Sent as X-Api-Key.
COGNEE_API_KEY=ck_your_key_here
# Optional but usually required on the SaaS tenant: sent as X-Tenant-Id / X-User-Id.
COGNEE_TENANT_ID=
COGNEE_USER_ID=
# Dataset name used for the shared memory graph
COGNEE_DATASET=codemind_repo_memory

# ===== Ollama Cloud (OpenAI-compatible) =====
# Get a key at https://ollama.com/settings/keys
OLLAMA_BASE_URL=https://ollama.com/v1
OLLAMA_API_KEY=
# Any model available on your Ollama Cloud account, e.g. qwen2.5:7b-instruct, gpt-oss:120b
OLLAMA_MODEL=qwen2.5:7b-instruct

# ===== Optional: real GitHub PR comments =====
# If unset, contradiction output is terminal + file only.
GH_TOKEN=
GH_REPO=owner/repo
GH_PR_NUMBER=