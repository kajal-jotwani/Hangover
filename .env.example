# ---- CodeMind environment ----
# Copy to .env and fill in. Never commit .env.

# Cognee Cloud (required for live memory graph)
COGNEE_URL=https://your-tenant.cognee.ai
COGNEE_API_KEY=ck_your_key_here

# Dataset name used for the shared memory graph
COGNEE_DATASET=codemind_repo_memory

# Local LLM via Ollama (OpenAI-compatible endpoint).
# Pull a model first, e.g.:  ollama pull qwen2.5:7b-instruct
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b-instruct

# Optional: real GitHub PR comments. If unset, output is terminal+file only.
GH_TOKEN=
GH_REPO=owner/repo
GH_PR_NUMBER=